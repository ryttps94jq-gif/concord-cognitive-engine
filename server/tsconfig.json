{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "logger.js",
    "lib/errors.js",
    "lib/async-handler.js",
    "lib/rate-limit.js",
    "middleware/**/*.js",
    "economy/guards.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
