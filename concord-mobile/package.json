{
  "name": "concord-mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.76.6",
    "expo": "~52.0.0",
    "expo-dev-client": "~5.0.0",
    "expo-status-bar": "~2.0.0",

    "@react-navigation/native": "^7.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "react-native-screens": "~4.4.0",
    "react-native-safe-area-context": "~5.0.0",

    "react-native-ble-plx": "^3.2.0",
    "react-native-wifi-p2p": "^2.1.0",
    "react-native-nfc-manager": "^3.14.0",
    "react-native-background-fetch": "^4.2.0",
    "react-native-background-actions": "^4.0.0",

    "react-native-fs": "^2.20.0",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-crypto": "^2.2.0",
    "react-native-device-info": "^11.1.0",
    "@react-native-community/geolocation": "^3.4.0",
    "react-native-sensors": "^7.3.0",

    "@react-native-async-storage/async-storage": "^2.1.0",
    "react-native-mmkv": "^3.2.0",

    "react-native-webrtc": "^124.0.0",

    "zustand": "^5.0.0",
    "immer": "^10.1.0",

    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "readable-stream": "^4.7.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "@types/react-native": "^0.73.0",
    "typescript": "~5.7.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/jest-native": "^5.4.0",
    "jest-expo": "~52.0.0",
    "@types/jest": "^29.5.0",
    "eslint": "^9.0.0",
    "detox": "^20.0.0",
    "react-test-renderer": "18.3.1"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": ["@testing-library/jest-native/extend-expect"],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx"],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|zustand))"
    ],
    "moduleNameMapper": {
      "^@surface/(.*)$": "<rootDir>/src/surface/$1",
      "^@mesh/(.*)$": "<rootDir>/src/mesh/$1",
      "^@foundation/(.*)$": "<rootDir>/src/foundation/$1",
      "^@dtu/(.*)$": "<rootDir>/src/dtu/$1",
      "^@economy/(.*)$": "<rootDir>/src/economy/$1",
      "^@shield/(.*)$": "<rootDir>/src/shield/$1",
      "^@brain/(.*)$": "<rootDir>/src/brain/$1",
      "^@broadcast/(.*)$": "<rootDir>/src/broadcast/$1",
      "^@store/(.*)$": "<rootDir>/src/store/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
