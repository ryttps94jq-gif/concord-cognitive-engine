{
  "name": "concord-frontend",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ../server/scripts/prophet-check.js && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "npx playwright test tests/e2e/accessibility.spec.ts",
    "type-check": "tsc --noEmit",
    "validate-routes": "npx tsx scripts/validate-routes.ts",
    "score-lenses": "npx tsx scripts/score-lenses.ts",
    "validate-lens-quality": "npx tsx scripts/validate-lens-quality.ts",
    "validate-lens-quality:strict": "npx tsx scripts/validate-lens-quality.ts --strict",
    "prepare": "husky"
  },
  "dependencies": {
    "@conform-to/zod": "^1.0.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.15.0",
    "@sentry/nextjs": "^10.50.0",
    "@tanstack/react-query": "^5.17.0",
    "@tiptap/extension-highlight": "^2.2.0",
    "@tiptap/extension-image": "^2.2.0",
    "@tiptap/extension-link": "^2.2.0",
    "@tiptap/extension-mention": "^2.2.0",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/extension-table": "^2.2.0",
    "@tiptap/extension-table-cell": "^2.2.0",
    "@tiptap/extension-table-header": "^2.2.0",
    "@tiptap/extension-table-row": "^2.2.0",
    "@tiptap/extension-task-item": "^2.2.0",
    "@tiptap/extension-task-list": "^2.2.0",
    "@tiptap/extension-typography": "^2.2.0",
    "@tiptap/react": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "@tiptap/suggestion": "^2.2.0",
    "@types/leaflet": "^1.9.21",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.6.5",
    "clsx": "^2.1.0",
    "cytoscape": "^3.28.1",
    "date-fns": "^3.2.0",
    "dexie": "^3.2.4",
    "framer-motion": "^11.0.3",
    "fuse.js": "^7.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.309.0",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.0.4",
    "next": "^15.5.15",
    "react": "^18.3.1",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^4.4.4",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.6.2",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.33",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "dompurify": "^3.4.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
