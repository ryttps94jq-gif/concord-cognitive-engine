
# Dependencies
node_modules/

# Server generated files
server/node_modules/
server/concord_state.json
concord_state.json
data/

# Un-ignore seed pack directory (canonical DTU source, committed to repo)
# gitignore requires un-ignoring each parent directory in the chain,
# then re-ignoring siblings we don't want tracked.
!server/data/
server/data/*
!server/data/seed/
!server/data/seed/**

# Test coverage output
coverage/

# Next.js build output (when built from root)
.next/
server/tests/.verification_scorecard.db

# Test parity state dumps (auto-generated, huge, per-run)
.parity-test-state-*.json
server/.parity-test-state-*.json

# Test data directories (auto-generated during E2E/integration runs)
server/.parity-test-data-*/

# Frontend build output (.next inside concord-frontend)
concord-frontend/.next/
concord-frontend/node_modules/

# Claude Code internal state (agent worktrees, plan files, etc.)
.claude/worktrees/
